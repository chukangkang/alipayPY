############################################################
# alipayPY 支付宝支付服务【改造版 - 支持 New-API】
# 
# 使用说明：
# 1. 复制此文件为 .env
# 2. 填入实际的支付宝配置和 New-API 配置
# 3. 运行 python app_api.py
############################################################

# ============================================================
# 【支付宝配置】- 必需
# ============================================================

# 支付宝应用ID（AppID）
ALIPAY_APP_ID=2021006132666221

# 应用私钥（签名用） - 不需要前缀后缀，SDK会自动添加
ALIPAY_APP_PRIVATE_KEY=MIIEvAIBADANBgkqhkiG9w0BAQEFAASCBKYwggSiAgEAAo...

# 支付宝公钥（验签用） - 不要前缀后缀，SDK会自动添加
ALIPAY_PUBLIC_KEY=MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA...

# 签名方式（RSA2 或 RSA）
ALIPAY_SIGN_TYPE=RSA2

# 格式
ALIPAY_FORMAT=json

# 字符集
ALIPAY_CHARSET=utf-8

# 是否为沙箱环境（测试环境）
# 值: true 或 false
ALIPAY_IS_SANDBOX=false

# 异步通知地址（生产环境必须是公网可访问的地址）
# 支付宝会在支付成功后回调此地址
ALIPAY_NOTIFY_URL=http://你的域名:5000/api/notify

# 同步返回地址（支付成功后返回的页面地址）
ALIPAY_RETURN_URL=http://你的域名:5000/alipay/return


# ============================================================
# 【New-API EPay 配置】- 新增【必需】
# ============================================================

# New-API 商户 ID（与 New-API 配置保持一致）
EPAY_MERCHANT_ID=1673765678

# New-API 商户密钥（与 New-API 配置保持一致）【关键！】
# 此密钥用于验证 New-API 的下单请求和签名回调
EPAY_MERCHANT_KEY=xm3787562987

# 本服务的公网地址（New-API 回调时使用）
# 例如：http://35wr35ep8134.vicp.fun 或 https://pay.example.com
EPAY_NOTIFY_BASE_URL=http://你的域名:5000


# ============================================================
# 【数据库配置】- 可选（默认使用 SQLite）
# ============================================================

# 数据库类型：sqlite / mysql（默认 sqlite）
DATABASE_TYPE=sqlite

# SQLite 配置（仅 DATABASE_TYPE=sqlite 时生效）
SQLITE_PATH=./data/orders.db

# MySQL 配置（仅 DATABASE_TYPE=mysql 时生效）
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=password
# MYSQL_DB=alipay_db


# ============================================================
# 【Flask 配置】
# ============================================================

FLASK_SECRET_KEY=your-secret-key-change-this-in-production
FLASK_ENV=development
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# 日志级别（DEBUG / INFO / WARNING / ERROR / CRITICAL）
LOG_LEVEL=INFO


# ============================================================
# 【配置说明】
# ============================================================

# 获取支付宝配置：
#   1. 登录蚂蚁开放平台 https://open.alipay.com
#   2. 创建应用或使用现有应用
#   3. 配置应用：
#      - 应用 ID 作为 ALIPAY_APP_ID
#      - 生成应用公钥/私钥对，私钥作为 ALIPAY_APP_PRIVATE_KEY
#      - 上传公钥到支付宝，下载支付宝公钥作为 ALIPAY_PUBLIC_KEY
#   4. 配置支付功能：
#      - 电脑网站支付 PC Pay
#      - 当面付 Face to Face Pay
#   5. 配置异步通知地址：
#      - 在应用设置中填入 ALIPAY_NOTIFY_URL

# New-API 配置获取方式：
#   1. 登录 New-API 后台
#   2. 进入"充值管理" → "支付方式"
#   3. 新增支付方式或编辑现有方式
#   4. 类型选择"EPay"
#   5. 填入商户 ID 和商户密钥，这两个值需要与本配置一致
#   6. 获取到的商户 ID 和密钥设置为 EPAY_MERCHANT_ID 和 EPAY_MERCHANT_KEY

# 生产建议：
#   ✓ 使用 HTTPS 访问地址
#   ✓ 不要提交 .env 文件到 Git（已在 .gitignore 中）
#   ✓ 使用强密钥，定期更换
#   ✓ 使用 MySQL 而非 SQLite（生产环境）
#   ✓ 配置日志监控
#   ✓ 配置数据库备份
